modules = ["python-3.11", "c-cpp"]

# This compiles the new time tracker C++ file instead
init = "pip install -r requirements.txt && g++ -O3 -Wall -shared -std=c++14 -fPIC $(python3 -m pybind11 --includes) time_core.cpp -o time_core$(python3-config --extension-suffix)"

# This tells Streamlit to launch the new time tracker UI
run = "streamlit run time_app.py --server.port=8080 --server.address=0.0.0.0"
