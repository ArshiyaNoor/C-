modules = ["python-3.11", "c-cpp"]

# Compiles C++ code instantly on Replit bootup using the Linux engine
init = "pip install -r requirements.txt && g++ -O3 -Wall -shared -std=c++14 -fPIC $(python3 -m pybind11 --includes) core.cpp -o healthcare_core$(python3-config --extension-suffix)"

# Commands Replit to host the web server
run = "streamlit run app.py --server.port=8080 --server.address=0.0.0.0"
